#include <iostream>
#include <fstream>
#include <string>
#include <algorithm>

using namespace std;

// Function to reverse file contents
void reverseFile(const string& inputFile, const string& outputFile) {
    ifstream inFile(inputFile);
    ofstream outFile(outputFile);

    if (!inFile || !outFile) {
        cout << "Error opening file." << endl;
        return;
    }

    // Read entire file into string
    string content((istreambuf_iterator<char>(inFile)),
                    istreambuf_iterator<char>());

    // Reverse the content
    reverse(content.begin(), content.end());

    // Write reversed content to new file
    outFile << content;

    inFile.close();
    outFile.close();
}

int main() {
    ofstream outFile("CSC450_CT5_mod5.txt", ios::app);

    if (!outFile) {
        cout << "Error opening file." << endl;
        return 1;
    }

    string userInput;

    cout << "Enter text to append to file: ";
    getline(cin, userInput);

    // Append input to file
    outFile << userInput << endl;
    outFile.close();

    // Reverse file contents
    reverseFile("CSC450_CT5_mod5.txt", "CSC450-mod5-reverse.txt");

    cout << "Data appended and reversed file created successfully." << endl;

    return 0;
} 
